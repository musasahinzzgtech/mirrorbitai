---
const heroImage =
  'https://lh3.googleusercontent.com/aida-public/AB6AXuCGEguU0mpxisfIrAjJBFG8ZPZGou2scED--zsBeQ_gHRhqscN5Uswa0C6vR_zXjizeX9OX47ddUhmpHe_VHsrc4pGVlTan9lw34SUYtTz2xxQyYiIxeoH74tYHzbc6fufqJddQzmyHhJl_-JKKUXvOF_FShGyiM5uQzSmHOCK_sVoUuYSUtBirCv-BZD8XN9wZfDEogHFif0iylFyZiPPCSQWoQG3dxGoqhAUNnc08H9GlfiOwH5MY7pB257qj2CX9Go8iFBPi3ac';
---

<section class="relative pt-28 pb-16 px-8 overflow-hidden flex items-center lg:pt-24">
  <div class="max-w-7xl mx-auto w-full relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-center">
      <!-- Left: Copy -->
      <div class="lg:col-span-5 space-y-6" data-animation="animate-fade-up animate-slide-in-left">
        <div class="space-y-3">
          <h1
            class="text-4xl lg:text-6xl font-headline font-extrabold tracking-tight text-gray-900 leading-[1.05]"
          >
            <span data-i18n="hero.headline.1" class="block">Building the</span>
            <span class="block">
              <span class="text-gradient-primary" data-i18n="hero.headline.2">Future</span>
              <span class="block">with AI.</span>
            </span>
          </h1>
        </div>

        <p
          class="text-sm text-gray-500 leading-relaxed max-w-md font-light tracking-wide"
          data-i18n="hero.description"
        >
          Mirrorbit AI creates intelligent, intuitive applications that transform how
          businesses operate and how people live. Meet the next generation of smart
          software.
        </p>

        <div class="flex flex-col sm:flex-row gap-3 pt-2">
          <a
            href="#products"
            class="group relative px-6 py-2.5 rounded-lg font-headline font-bold text-white bg-gray-900 hover:bg-black overflow-hidden transition-all duration-300 hover:scale-105 hover:shadow-lg active:scale-95 inline-flex items-center justify-center gap-2"
            data-i18n="hero.cta.primary"
          >
            <span class="relative z-10">Explore Products</span>
            <span class="material-symbols-outlined relative z-10 text-base">arrow_forward</span>
          </a>
          <a
            href="#about"
            class="glass-btn px-6 py-2.5 rounded-lg font-headline font-bold text-gray-900 inline-flex items-center justify-center gap-2"
            data-i18n="hero.cta.secondary"
          >
            <span>Learn More</span>
            <span class="material-symbols-outlined text-base">help_outline</span>
          </a>
        </div>
      </div>

      <!-- Right: Visual -->
      <div class="lg:col-span-7 relative" data-animation="animate-fade-up animate-slide-in-right animation-delay-200">
        <div class="relative">
          <div class="relative rounded-xl overflow-hidden premium-card group cursor-pointer">
            <img
              src={heroImage}
              alt="Modern minimalist 3D abstract digital environment with glass spheres and blue glowing crystalline structures"
              class="w-full h-auto object-cover aspect-[5/4] transition-transform duration-500 group-hover:scale-105"
              loading="eager"
            />
            <div
              class="absolute inset-0 bg-gradient-to-t from-black/10 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"
            ></div>
          </div>

          <!-- Floating stats card -->
          <div
            class="absolute -bottom-4 -left-4 glass-card p-4 rounded-xl backdrop-blur-md hidden md:block animate-float shadow-lg"
            data-animation="animate-scale-in animation-delay-300"
          >
            <div class="flex items-center gap-3">
              <div class="bg-gray-900/8 p-2.5 rounded-lg border border-black/8">
                <span class="material-symbols-outlined text-gray-900 text-xl">bolt</span>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-0.5">Performance</p>
                <p class="text-sm font-bold text-gray-900" data-i18n="hero.card.title">99.9% Uptime</p>
                <p class="text-xs text-gray-500" data-i18n="hero.card.subtitle">Real-time Processing</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
