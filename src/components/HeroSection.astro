---
---

<section class="relative pt-28 pb-20 px-6 lg:px-10 overflow-hidden">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Left: Copy -->
      <div class="space-y-7" data-animation="animate-fade-up">


        <h1
          class="headline-display text-[52px] md:text-[64px] lg:text-[72px] text-[#1D1D1F]"
          data-animation="animate-fade-up animation-delay-100"
        >
          <span class="block" data-i18n="hero.headline.1">Intelligence,</span>
          <span class="block text-[#6E6E73]" data-i18n="hero.headline.2">by design.</span>
        </h1>

        <p
          class="body-copy text-[17px] lg:text-[19px] max-w-sm"
          data-i18n="hero.description"
        >
          Mirrorbit AI engineers precision tools that transform how businesses operate and how
          people live. The next generation of smart software.
        </p>

        <div class="flex flex-col sm:flex-row gap-3 pt-1">
          <a
            href="/#products"
            class="apple-btn-dark"
            data-i18n="hero.cta.primary"
          >
            Explore Products
            <span
              class="material-symbols-outlined"
              style="font-size: 17px; font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;"
            >arrow_forward</span>
          </a>
          <a
            href="/about"
            class="apple-btn-ghost"
            data-i18n="hero.cta.secondary"
          >
            Learn More
            <span
              class="material-symbols-outlined"
              style="font-size: 17px; font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;"
            >chevron_right</span>
          </a>
        </div>

        <!-- Stats -->
        <div
          class="flex gap-8 pt-5 border-t border-[#D2D2D7]"
          data-animation="animate-fade-up animation-delay-300"
        >
          {[
            { value: '99.9%', label: 'Uptime' },
            { value: '2M+',   label: 'Meals Analyzed' },
            { value: '500+',  label: 'Restaurants' },
          ].map(s => (
            <div>
              <p class="text-[28px] font-bold text-[#1D1D1F]" style="letter-spacing: -0.04em; line-height: 1;">
                {s.value}
              </p>
              <p class="text-[13px] text-[#6E6E73] mt-1.5" style="letter-spacing: -0.01em;">{s.label}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: Image -->
      <div
        class="relative flex justify-center lg:justify-end"
        data-animation="animate-fade-up animation-delay-200"
      >
        <div class="relative w-full max-w-[420px]">
          <!-- Main image frame -->
          <div
            class="rounded-[28px] overflow-hidden"
            style="border: 1px solid rgba(210,210,215,0.7); box-shadow: 0 24px 64px rgba(0,0,0,0.09), 0 4px 16px rgba(0,0,0,0.05);"
          >
            <img
              src="/office.jpg"
              alt="Mirrorbit AI platform — 3D abstract digital environment"
              class="w-full object-cover"
              style="height: 360px; object-position: center;"
              loading="eager"
            />
          </div>

          <!-- Floating badge -->
          <div
            class="absolute -bottom-4 -left-6 hidden md:flex items-center gap-3 bg-white rounded-2xl px-4 py-3"
            style="box-shadow: 0 4px 20px rgba(0,0,0,0.08), 0 1px 4px rgba(0,0,0,0.04); border: 1px solid rgba(210,210,215,0.6);"
            data-animation="animate-scale-in animation-delay-400"
          >
            <div
              class="w-9 h-9 rounded-xl flex items-center justify-center bg-[#F5F5F7]"
              style="border: 1px solid rgba(210,210,215,0.6);"
            >
              <span
                class="material-symbols-outlined text-[#1D1D1F]"
                style="font-size: 18px; font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;"
              >bolt</span>
            </div>
            <div>
              <p class="text-[11px] font-medium text-[#AEAEB2] uppercase tracking-wider" data-i18n="hero.card.title">
                99.9% Uptime
              </p>
              <p class="text-[13px] font-semibold text-[#1D1D1F]" data-i18n="hero.card.subtitle">
                Real-time Processing
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
