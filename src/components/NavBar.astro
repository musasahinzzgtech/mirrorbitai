---
import LangSwitcher from './LangSwitcher.astro';

const pathname = Astro.url.pathname;

const navLinks = [
  { label: 'Products',  i18n: 'nav.products', href: '/#products', isPage: false },
  { label: 'Services',  i18n: null,            href: '/services',  isPage: true  },
  { label: 'About',     i18n: 'nav.about',     href: '/about',     isPage: true  },
  { label: 'Blog',      i18n: null,            href: '/blog',      isPage: true  },
  { label: 'Contact',   i18n: 'nav.contact',   href: '/contact',   isPage: true  },
];
---

<nav
  class="fixed top-0 w-full z-50 transition-all duration-300"
  style="background: rgba(251,251,253,0.85); backdrop-filter: saturate(180%) blur(20px); -webkit-backdrop-filter: saturate(180%) blur(20px); border-bottom: 1px solid rgba(210,210,215,0.5);"
>
  <div class="flex justify-between items-center max-w-7xl mx-auto px-6 lg:px-10" style="height: 52px;">
    <!-- Logo -->
    <a
      href="/"
      class="text-[17px] font-semibold text-[#1D1D1F] hover:opacity-75 transition-opacity tracking-tight"
      style="letter-spacing: -0.02em;"
    >
      Mirrorbit AI
    </a>

    <!-- Desktop Links -->
    <div class="hidden md:flex items-center gap-7">
      {navLinks.map((link) => {
        const isActive = link.isPage &&
          (pathname === link.href || pathname.startsWith(link.href + '/'));
        return (
          <a
            href={link.href}
            class={`nav-link${isActive ? ' page-active' : ''}`}
            data-i18n={link.i18n || undefined}
          >
            {link.label}
          </a>
        );
      })}
    </div>

    <!-- Right side -->
    <div class="hidden md:flex items-center gap-4">
      <LangSwitcher />
      <a
        href="/contact"
        class="apple-btn-dark"
        style="padding: 7px 16px; font-size: 13px;"
        data-i18n="nav.cta"
      >
        Get in Touch
      </a>
    </div>

    <!-- Mobile toggle -->
    <button
      id="mobile-menu-btn"
      class="md:hidden text-[#1D1D1F] hover:opacity-70 transition-opacity p-2 -mr-2"
      aria-label="Toggle menu"
    >
      <span class="material-symbols-outlined" style="font-size: 22px; font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;">menu</span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t"
    style="background: rgba(251,251,253,0.97); backdrop-filter: blur(20px); border-color: rgba(210,210,215,0.6);"
  >
    <div class="px-4 py-3 space-y-0.5">
      {navLinks.map((link) => {
        const isActive = link.isPage &&
          (pathname === link.href || pathname.startsWith(link.href + '/'));
        return (
          <a
            href={link.href}
            class={`block px-4 py-3 rounded-xl text-[15px] font-normal transition-colors ${
              isActive
                ? 'text-[#1D1D1F] bg-[#F5F5F7] font-medium'
                : 'text-[#1D1D1F] hover:bg-[#F5F5F7]'
            }`}
            data-i18n={link.i18n || undefined}
          >
            {link.label}
          </a>
        );
      })}
      <div class="pt-4 pb-2 px-4 space-y-3 border-t" style="border-color: rgba(210,210,215,0.6);">
        <LangSwitcher />
        <a
          href="/contact"
          class="apple-btn-dark w-full justify-center"
          style="font-size: 15px;"
          data-i18n="nav.cta"
        >
          Get in Touch
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  });
</script>
