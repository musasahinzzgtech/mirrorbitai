---
import LangSwitcher from './LangSwitcher.astro';

const navLinks = [
  { label: 'nav.home', href: '#', sectionId: null },
  { label: 'nav.products', href: '#products', sectionId: 'products' },
  { label: 'nav.about', href: '#about', sectionId: 'about' },
  { label: 'nav.contact', href: '#contact', sectionId: 'contact' },
];
---

<nav class="fixed top-0 w-full z-50 bg-slate-950/40 backdrop-blur-xl shadow-2xl shadow-blue-900/10 transition-all duration-300">
  <div class="flex justify-between items-center max-w-7xl mx-auto px-8 h-20">
    <!-- Logo -->
    <a href="/" class="text-2xl font-bold tracking-tighter text-slate-100 font-headline hover:text-blue-400 transition-colors duration-300">
      Mirrorbit AI
    </a>

    <!-- Desktop Links -->
    <div class="hidden md:flex items-center space-x-10">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="nav-link text-slate-400 hover:text-slate-100 transition-all duration-300 font-headline text-sm font-medium tracking-tight pb-1 border-b-2 border-transparent hover:border-blue-500/30"
            data-section={link.sectionId}
            data-i18n={link.label}
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden text-slate-400 hover:text-slate-100 transition-colors"
      aria-label="Toggle menu"
    >
      <span class="material-symbols-outlined">menu</span>
    </button>

    <!-- Language Switcher & CTA -->
    <div class="hidden md:flex items-center gap-4">
      <LangSwitcher />
      <button
        class="bg-primary hover:bg-primary-dim text-on-primary px-6 py-2.5 rounded-full font-headline font-bold text-sm scale-95 active:scale-90 transition-all duration-300"
        data-i18n="nav.cta"
      >
        Get in Touch
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-slate-800/50 bg-slate-950/90 backdrop-blur-xl"
  >
    <div class="px-8 py-6 space-y-4">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="mobile-nav-link block text-slate-400 hover:text-slate-100 transition-colors font-headline text-sm font-medium"
            data-section={link.sectionId}
            data-i18n={link.label}
          >
            {link.label}
          </a>
        ))
      }
      <div class="pt-4 space-y-3 border-t border-slate-800/50">
        <LangSwitcher />
        <button
          class="w-full bg-primary hover:bg-primary-dim text-on-primary px-6 py-2.5 rounded-full font-headline font-bold text-sm transition-all duration-300"
          data-i18n="nav.cta"
        >
          Get in Touch
        </button>
      </div>
    </div>
  </div>
</nav>

<script>
  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));

  // Active nav link highlighting based on scroll position
  function updateActiveNav() {
    const navLinks = document.querySelectorAll('.nav-link, .mobile-nav-link');
    const sections = Array.from(navLinks).map(link => ({
      link,
      sectionId: link.getAttribute('data-section'),
    }));

    // Reset all links
    navLinks.forEach(link => {
      link.classList.remove('text-blue-400', 'font-bold', 'border-blue-500/50');
      link.classList.add('text-slate-400', 'font-medium');
    });

    // Mark home as active if at top
    if (window.scrollY < 100) {
      sections[0]?.link?.classList.add('text-blue-400', 'font-bold', 'border-blue-500/50');
      sections[0]?.link?.classList.remove('text-slate-400', 'font-medium');
      return;
    }

    // Check which section is in view
    for (const { link, sectionId } of sections) {
      if (!sectionId) continue;

      const section = document.getElementById(sectionId);
      if (section) {
        const rect = section.getBoundingClientRect();
        // Consider section in view if it's in the top half of viewport
        if (rect.top < window.innerHeight / 2 && rect.bottom > 0) {
          link.classList.add('text-blue-400', 'font-bold', 'border-blue-500/50');
          link.classList.remove('text-slate-400', 'font-medium');
          break;
        }
      }
    }
  }

  // Update on scroll and on page load
  window.addEventListener('scroll', updateActiveNav, { passive: true });
  document.addEventListener('DOMContentLoaded', updateActiveNav);
  updateActiveNav(); // Initial call
</script>

<style>
  /* Smooth transition for nav link changes */
  .nav-link,
  .mobile-nav-link {
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
</style>
