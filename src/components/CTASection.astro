---
---

<section class="py-24 px-6 lg:px-10">
  <div class="max-w-7xl mx-auto">
    <div
      class="rounded-[32px] bg-[#1D1D1F] px-8 md:px-16 py-16 md:py-20 text-center relative overflow-hidden"
    >
      <!-- Subtle radial glow -->
      <div
        class="absolute inset-0 pointer-events-none"
        style="background: radial-gradient(ellipse 70% 50% at 50% 0%, rgba(0,113,227,0.28), transparent); opacity: 1;"
      ></div>

      <div class="relative z-10">
        <p class="text-white/50 text-[12px] font-medium tracking-[0.1em] uppercase mb-4">
          Get Started
        </p>
        <h2
          class="headline-section text-[40px] lg:text-[52px] text-white mb-4"
          data-i18n="cta.title"
        >
          Ready for the AI revolution?
        </h2>
        <p
          class="text-white/60 text-[17px] mb-10 max-w-md mx-auto leading-relaxed"
          data-i18n="cta.subtitle"
        >
          Join thousands of users and businesses already scaling with Mirrorbit AI.
        </p>

        <div class="flex flex-wrap justify-center gap-3">
          <a
            href="/contact"
            class="bg-white text-[#1D1D1F] rounded-full px-7 py-3.5 text-[15px] font-medium hover:bg-white/90 transition-colors inline-flex items-center gap-2"
            data-i18n="cta.primary"
          >
            Get Started Free
          </a>
          <a
            href="/contact"
            class="text-white/80 hover:text-white rounded-full px-7 py-3.5 text-[15px] font-medium border hover:border-white/40 transition-all inline-flex items-center gap-2"
            style="border-color: rgba(255,255,255,0.2);"
            data-i18n="cta.secondary"
          >
            Talk to Sales
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
