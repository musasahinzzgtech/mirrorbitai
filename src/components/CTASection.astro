<section id="contact" class="py-16 px-8 scroll-mt-16">
  <div
    class="max-w-5xl mx-auto rounded-2xl bg-gray-900 p-8 md:p-12 text-center relative overflow-hidden"
  >
    <div class="relative z-10">
      <h2
        class="text-xl md:text-2xl font-headline font-extrabold text-white mb-4"
        data-i18n="cta.title"
      >
        Ready to Experience the AI Revolution?
      </h2>
      <p
        class="text-sm text-white/70 mb-8 max-w-xl mx-auto"
        data-i18n="cta.subtitle"
      >
        Join thousands of users and businesses already scaling with Mirrorbit AI
        technologies.
      </p>

      <div class="flex flex-wrap justify-center gap-4">
        <button
          class="bg-white text-gray-900 px-6 py-2.5 rounded-lg font-headline font-bold text-sm hover:bg-gray-100 transition-colors shadow-md"
          data-i18n="cta.primary"
        >
          Get Started Free
        </button>
        <button
          class="bg-white/10 border border-white/20 text-white px-6 py-2.5 rounded-lg font-headline font-bold text-sm hover:bg-white/15 transition-colors"
          data-i18n="cta.secondary"
        >
          Talk to Sales
        </button>
      </div>
    </div>
  </div>
</section>
