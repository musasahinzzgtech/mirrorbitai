---
---

<section id="contact" class="py-24 px-8">
  <div
    class="max-w-5xl mx-auto rounded-3xl bg-gradient-to-br from-primary-dim to-secondary-dim p-12 md:p-20 text-center relative overflow-hidden shadow-2xl"
  >
    <!-- Texture overlay -->
    <div
      class="absolute inset-0 opacity-10"
      style="background-image: url('https://www.transparenttextures.com/patterns/carbon-fibre.png')"
    >
    </div>

    <div class="relative z-10">
      <h2
        class="text-3xl md:text-5xl font-headline font-extrabold text-on-primary-fixed mb-6"
      >
        Ready to Experience the AI Revolution?
      </h2>
      <p class="text-lg md:text-xl text-on-primary-fixed/80 mb-10 max-w-2xl mx-auto">
        Join thousands of users and businesses already scaling with Mirrorbit AI
        technologies.
      </p>

      <div class="flex flex-wrap justify-center gap-6">
        <button
          class="bg-white text-slate-950 px-10 py-4 rounded-lg font-headline font-bold hover:scale-105 transition-transform shadow-xl"
        >
          Get Started Free
        </button>
        <button
          class="bg-slate-950/20 backdrop-blur-md border border-white/30 text-white px-10 py-4 rounded-lg font-headline font-bold hover:bg-slate-950/30 transition-colors"
        >
          Talk to Sales
        </button>
      </div>
    </div>
  </div>
</section>
