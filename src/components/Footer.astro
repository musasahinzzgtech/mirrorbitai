---
const links = [
  { label: 'footer.privacy', href: '#' },
  { label: 'footer.terms', href: '#' },
  { label: 'footer.twitter', href: '#' },
  { label: 'footer.linkedin', href: '#' },
];
---

<footer class="w-full py-8 border-t border-gray-100 bg-white">
  <div
    class="max-w-7xl mx-auto px-8 grid grid-cols-1 md:grid-cols-2 gap-6 items-center"
  >
    <!-- Brand -->
    <div class="space-y-2">
      <div class="text-base font-bold text-gray-900 font-headline">Mirrorbit AI</div>
      <p class="text-xs text-gray-400 max-w-sm font-body" data-i18n="footer.copy">
        © {new Date().getFullYear()} Mirrorbit AI. All rights reserved. Precision software for a
        digital-first world.
      </p>
    </div>

    <!-- Footer Links -->
    <div class="flex flex-wrap md:justify-end gap-6">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="text-xs text-gray-400 hover:text-gray-900 transition-colors font-body"
            data-i18n={link.label}
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </div>
</footer>
