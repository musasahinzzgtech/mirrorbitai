---
const features = [
  {
    icon: 'bolt',
    title: 'Speed',
    description:
      'Real-time AI processing that delivers instant results to end-users, optimized for low-latency interactions.',
    i18n: { title: 'why.speed.title', desc: 'why.speed.desc' },
  },
  {
    icon: 'verified',
    title: 'Accuracy',
    description:
      'State-of-the-art computer vision and machine learning models trained on proprietary high-quality datasets.',
    i18n: { title: 'why.accuracy.title', desc: 'why.accuracy.desc' },
  },
  {
    icon: 'draw',
    title: 'Design',
    description:
      'Beautiful, frictionless user interfaces built for everyday use, following our high-precision optical framework.',
    i18n: { title: 'why.design.title', desc: 'why.design.desc' },
  },
];
---

<section id="about" class="py-24 px-6 lg:px-10 scroll-mt-16">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-14">
      <p class="text-[#1D1D1F] text-[12px] font-medium tracking-[0.1em] uppercase mb-3">
        Why Mirrorbit
      </p>
      <h2
        class="headline-section text-[40px] lg:text-[48px] text-[#1D1D1F] max-w-2xl mx-auto"
        data-i18n="why.title"
      >
        The Mirrorbit Advantage
      </h2>
      <p
        class="body-copy text-[17px] max-w-lg mx-auto mt-4"
        data-i18n="why.subtitle"
      >
        We don't just build apps — we engineer precision instruments powered by the latest
        breakthroughs in neural technology.
      </p>
    </div>

    <!-- Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {features.map((f) => (
        <div class="feature-card space-y-4">
          <div
            class="w-11 h-11 rounded-2xl bg-white flex items-center justify-center"
            style="box-shadow: 0 2px 8px rgba(0,0,0,0.06); border: 1px solid rgba(210,210,215,0.7);"
          >
            <span
              class="material-symbols-outlined text-[#1D1D1F]"
              style="font-size: 20px; font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;"
            >
              {f.icon}
            </span>
          </div>
          <h4
            class="text-[19px] font-semibold text-[#1D1D1F] tracking-tight"
            data-i18n={f.i18n.title}
          >
            {f.title}
          </h4>
          <p
            class="text-[15px] text-[#6E6E73] leading-relaxed"
            data-i18n={f.i18n.desc}
          >
            {f.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
