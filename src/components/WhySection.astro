---
const features = [
  {
    icon: 'bolt',
    title: 'Speed',
    description:
      'Real-time AI processing that delivers instant results to end-users, optimized for low-latency interactions.',
  },
  {
    icon: 'verified',
    title: 'Accuracy',
    description:
      'State-of-the-art computer vision and machine learning models trained on proprietary high-quality datasets.',
  },
  {
    icon: 'draw',
    title: 'Design',
    description:
      'Beautiful, frictionless user interfaces built for everyday use, following our high-precision optical framework.',
  },
];
---

<section id="about" class="py-16 px-8 relative overflow-hidden scroll-mt-16">
  <div class="max-w-7xl mx-auto relative z-10">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <h2
        class="text-2xl md:text-3xl font-headline font-extrabold tracking-tight mb-3 text-gray-900"
        data-i18n="why.title"
      >
        The Mirrorbit Advantage
      </h2>
      <p class="text-sm text-gray-900-variant max-w-xl mx-auto" data-i18n="why.subtitle">
        We don't just build apps; we engineer precision instruments powered by the latest
        breakthroughs in neural technology.
      </p>
    </div>

    <!-- Feature Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {
        features.map((feature) => (
          <div class="p-6 rounded-xl bg-white border border-gray-100 hover:border-gray-200 hover:shadow-md transition-all duration-300 flex flex-col items-center text-center space-y-4">
            <div class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center">
              <span class="material-symbols-outlined text-xl text-gray-900">
                {feature.icon}
              </span>
            </div>
            <h4
              class="text-base font-headline font-bold text-gray-900"
              data-i18n={`why.${feature.title.toLowerCase()}.title`}
            >
              {feature.title}
            </h4>
            <p
              class="text-sm text-gray-900-variant leading-relaxed"
              data-i18n={`why.${feature.title.toLowerCase()}.desc`}
            >
              {feature.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
