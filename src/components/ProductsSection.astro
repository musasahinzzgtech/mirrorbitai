---
const products = [
  {
    id: 'slaycal',
    name: 'SlayCal',
    badge: 'B2C',
    description:
      'Your personal AI nutrition coach and chef. Snap a photo of your meal for instant macros, or scan your fridge for customized recipes.',
    image:
      'slaycal.png',
    imageAlt: 'Close-up of a vibrant healthy poke bowl with AI interface overlay',
    features: [
      { icon: 'camera_alt', label: 'Meal Scanner' },
      { icon: 'track_changes', label: 'Smart Goals' },
      { icon: 'water_drop', label: 'Hydration' },
    ],
    href: 'https://slaycal.com/',
    cta: 'View SlayCal',
    ctaIcon: 'smartphone',
    i18n: {
      desc: 'slaycal.description',
      cta: 'slaycal.cta',
      f1: 'slaycal.feature1',
      f2: 'slaycal.feature2',
      f3: 'slaycal.feature3',
    },
  },
  {
    id: 'qrmenu',
    name: 'Restaurant Managment System',
    badge: 'B2B',
    description:
      'Transform printed menus into digital experiences in seconds. Snap a photo, let AI extract the dishes, and launch instantly with real-time order tracking.',
    image:
      'restoran.png',
    imageAlt: 'Interior of a modern restaurant with a minimalist QR code stand',
    features: [
      { icon: 'speed', label: '2-Min Setup' },
      { icon: 'monitoring', label: 'Live Tracking' },
      { icon: 'apartment', label: 'Multi-Branch' },
    ],
    href: 'https://restoranqrmenum.com/',
    cta: 'Explore QRMenu Solutions',
    ctaIcon: 'rocket_launch',
    i18n: {
      desc: 'qrmenu.description',
      cta: 'qrmenu.cta',
      f1: 'qrmenu.feature1',
      f2: 'qrmenu.feature2',
      f3: 'qrmenu.feature3',
    },
  },
];
---

<section id="products" class="py-24 px-6 lg:px-10 apple-section-alt scroll-mt-16">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="mb-14">
      <p class="text-[#1D1D1F] text-[12px] font-medium tracking-[0.1em] uppercase mb-3">
        Our Products
      </p>
      <h2
        class="headline-section text-[40px] lg:text-[48px] text-[#1D1D1F]"
        data-i18n="products.title"
      >
        Flagship Innovations
      </h2>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {products.map((product) => (
        <article class="apple-card overflow-hidden group">
          <!-- Image — fixed height, no zoom on overflow -->
          <div class="overflow-hidden bg-[#F5F5F7]">
            <img
              src={product.image}
              alt={product.imageAlt}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.03]"
              loading="lazy"
            />
          </div>

          <!-- Body -->
          <div class="p-7 space-y-5">
            <!-- Title + badge -->
            <div>
              <div class="flex items-center gap-2.5 mb-2">
                <h3 class="text-[22px] font-semibold text-[#1D1D1F] tracking-tight">
                  {product.name}
                </h3>
                <span
                  class="text-[11px] font-medium text-[#6E6E73] px-2 py-0.5 rounded-full border border-[#D2D2D7] uppercase tracking-wider"
                >
                  {product.badge}
                </span>
              </div>
              <p
                class="text-[15px] text-[#6E6E73] leading-relaxed"
                data-i18n={product.i18n.desc}
              >
                {product.description}
              </p>
            </div>

            <!-- Feature pills -->
            <div class="flex flex-wrap gap-2">
              {product.features.map((f, idx) => (
                <div class="flex items-center gap-1.5 bg-[#F5F5F7] px-3 py-1.5 rounded-full">
                  <span
                    class="material-symbols-outlined text-[#6E6E73]"
                    style="font-size: 14px; font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 20;"
                  >
                    {f.icon}
                  </span>
                  <span
                    class="text-[13px] text-[#1D1D1F]"
                    data-i18n={idx === 0 ? product.i18n.f1 : idx === 1 ? product.i18n.f2 : product.i18n.f3}
                  >
                    {f.label}
                  </span>
                </div>
              ))}
            </div>

            <!-- CTA link -->
            <a
              href={product.href}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 text-[#1D1D1F] text-[14px] hover:opacity-75 transition-opacity"
              data-i18n={product.i18n.cta}
            >
              {product.cta}
              <span
                class="material-symbols-outlined"
                style="font-size: 15px; font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 20;"
              >chevron_right</span>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
