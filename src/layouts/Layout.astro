---
import { ViewTransitions } from 'astro:transitions';
import { translations } from '../i18n/translations.js';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Mirrorbit AI | Building the Future with Artificial Intelligence',
  description = 'Mirrorbit AI creates intelligent, intuitive applications that transform how businesses operate and how people live.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffffff" />
    <title>{title}</title>

    <!-- Open Graph / SEO -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://mirrorbitai.com/" />
    <meta property="og:image" content="https://mirrorbitai.com/og-image.jpg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://mirrorbitai.com/og-image.jpg" />

    <!-- Canonical -->
    <link rel="canonical" href="https://mirrorbitai.com/" />

    <!-- Additional SEO -->
    <meta name="keywords" content="AI, nutrition, food recognition, recipe discovery, restaurant menu, SlayCal, QRMenu" />
    <meta name="author" content="Mirrorbit AI" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=5" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
      rel="stylesheet"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preload critical resources -->
    <link rel="preload" as="font" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" type="font/woff2" crossorigin />

    <!-- View Transitions for app-like navigation -->
    <ViewTransitions />

    <!-- JSON-LD Schema -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "Organization",
            "@id": "https://mirrorbitai.com/#organization",
            "name": "Mirrorbit AI",
            "description": "AI-powered software for nutrition tracking and restaurant management",
            "url": "https://mirrorbitai.com",
            "logo": {
              "@type": "ImageObject",
              "url": "https://mirrorbitai.com/favicon.svg"
            },
            "sameAs": [
              "https://twitter.com/mirrorbitai",
              "https://linkedin.com/company/mirrorbitai"
            ],
            "contactPoint": {
              "@type": "ContactPoint",
              "contactType": "Customer Support",
              "email": "support@mirrorbitai.com"
            }
          },
          {
            "@type": "WebSite",
            "@id": "https://mirrorbitai.com/#website",
            "url": "https://mirrorbitai.com",
            "name": "Mirrorbit AI",
            "description": "Building the Future with Artificial Intelligence",
            "publisher": {
              "@id": "https://mirrorbitai.com/#organization"
            },
            "potentialAction": {
              "@type": "SearchAction",
              "target": "https://mirrorbitai.com/?s={search_term_string}",
              "query-input": "required name=search_term_string"
            }
          },
          {
            "@type": "Product",
            "@id": "https://mirrorbitai.com/#product-slaycal",
            "name": "SlayCal",
            "description": "Personal AI nutrition coach and chef. Snap a photo of your meal for instant macros.",
            "brand": {
              "@type": "Brand",
              "name": "Mirrorbit AI"
            },
            "manufacturer": {
              "@id": "https://mirrorbitai.com/#organization"
            }
          },
          {
            "@type": "Product",
            "@id": "https://mirrorbitai.com/#product-qrmenu",
            "name": "Restaurant Managment System",
            "description": "Transform printed menus into digital experiences with AI-powered menu extraction.",
            "brand": {
              "@type": "Brand",
              "name": "Mirrorbit AI"
            },
            "manufacturer": {
              "@id": "https://mirrorbitai.com/#organization"
            }
          }
        ]
      }
    </script>
  </head>
  <body class="selection:bg-gray-200 antialiased relative z-10">
    <slot />

    <!-- Translations for client-side i18n -->
    <script define:vars={{ translations }}>
      window.__translations = translations;

      // Initialize language on page load and after every View Transition
      document.addEventListener('astro:page-load', () => {
        const lang = localStorage.getItem('lang') || 'en';
        document.documentElement.lang = lang;
        document.querySelectorAll('[data-i18n]').forEach((el) => {
          const key = el.getAttribute('data-i18n');
          const text = window.__translations[lang]?.[key] || key;
          el.textContent = text.replace('{year}', new Date().getFullYear());
        });
      });
    </script>

    <!-- Scroll animations -->
    <script>
      const observerOptions = {
        threshold: 0.1,
        rootMargin: '0px 0px -60px 0px',
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target;
            const delay = el.getAttribute('data-animation-delay');
            const classes = el.getAttribute('data-animation')?.split(' ') || [];

            if (delay) {
              el.style.animationDelay = delay;
            }

            classes.forEach((cls) => el.classList.add(cls));
            observer.unobserve(el);
          }
        });
      }, observerOptions);

      document.addEventListener('astro:page-load', () => {
        document.querySelectorAll('[data-animation]').forEach((el) => {
          observer.observe(el);
        });
      });
    </script>
  </body>
</html>
