---
import Layout from '../../layouts/Layout.astro';
import NavBar from '../../components/NavBar.astro';
import Footer from '../../components/Footer.astro';
import { blogPosts } from '../../data/blogPosts.js';
import '../../styles/global.css';

const [featured, ...rest] = blogPosts;
---

<Layout
  title="Blog — Mirrorbit AI"
  description="Insights on AI, design, and engineering from the Mirrorbit AI team."
>
  <NavBar />
  <main class="pt-[52px]">

    <!-- Header -->
    <section class="py-24 px-6 lg:px-10">
      <div class="max-w-7xl mx-auto">
        <p class="text-[12px] font-medium tracking-[0.1em] uppercase mb-4 text-[#6E6E73]">
          Newsroom
        </p>
        <h1 class="headline-display text-[56px] lg:text-[72px] text-[#1D1D1F]">Blog</h1>
        <p class="body-copy text-[19px] mt-4 max-w-md">
          Thoughts on AI, design, and building software people love.
        </p>
      </div>
    </section>

    <div class="apple-divider max-w-7xl mx-auto px-6 lg:px-10"></div>

    <!-- Posts -->
    <section class="py-20 px-6 lg:px-10">
      <div class="max-w-7xl mx-auto space-y-5">

        <!-- Featured -->
        <a href={`/blog/${featured.slug}`} class="featured-card group block">
          <div
            class="grid grid-cols-1 lg:grid-cols-2 overflow-hidden rounded-[20px] border border-[#D2D2D7] hover:border-transparent hover:shadow-[0_8px_40px_rgba(0,0,0,0.08)] transition-all duration-300"
          >
            <div
              class={`h-56 lg:h-auto min-h-[300px] bg-gradient-to-br ${featured.gradient} flex items-end p-8`}
            >
              <span
                class="text-[12px] font-medium text-white/90 bg-black/20 px-3 py-1.5 rounded-full backdrop-blur-sm"
              >
                {featured.category}
              </span>
            </div>
            <div class="p-8 lg:p-12 flex flex-col justify-center bg-white">
              <p class="text-[12px] text-[#AEAEB2] mb-4 tracking-wide">
                {featured.date} &middot; {featured.readTime}
              </p>
              <h2
                class="headline-section text-[26px] lg:text-[30px] text-[#1D1D1F] mb-4 group-hover:opacity-70 transition-opacity"
              >
                {featured.title}
              </h2>
              <p class="text-[16px] text-[#6E6E73] leading-relaxed mb-7">
                {featured.excerpt}
              </p>
              <span
                class="inline-flex items-center gap-1.5 text-[14px] font-medium text-[#1D1D1F]"
              >
                Read article
                <span
                  class="material-symbols-outlined transition-transform duration-200 group-hover:translate-x-1"
                  style="font-size: 16px; font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 20;"
                >arrow_forward</span>
              </span>
            </div>
          </div>
        </a>

        <!-- Remaining posts -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
          {rest.map((post) => (
            <a href={`/blog/${post.slug}`} class="blog-card group">
              <div
                class={`h-[180px] bg-gradient-to-br ${post.gradient} flex items-end p-5`}
              >
                <span
                  class="text-[11px] font-medium text-white/90 bg-black/20 px-2.5 py-1 rounded-full backdrop-blur-sm"
                >
                  {post.category}
                </span>
              </div>
              <div class="p-6 space-y-3">
                <p class="text-[12px] text-[#AEAEB2] tracking-wide">
                  {post.date} &middot; {post.readTime}
                </p>
                <h3
                  class="text-[17px] font-semibold text-[#1D1D1F] leading-snug group-hover:opacity-70 transition-opacity"
                  style="letter-spacing: -0.02em;"
                >
                  {post.title}
                </h3>
                <p
                  class="text-[14px] text-[#6E6E73] leading-relaxed"
                  style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;"
                >
                  {post.excerpt}
                </p>
                <p
                  class="inline-flex items-center gap-1 text-[13px] font-medium text-[#1D1D1F] pt-1"
                >
                  Read
                  <span
                    class="material-symbols-outlined transition-transform duration-200 group-hover:translate-x-0.5"
                    style="font-size: 14px; font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 20;"
                  >arrow_forward</span>
                </p>
              </div>
            </a>
          ))}
        </div>

      </div>
    </section>

  </main>
  <Footer />
</Layout>
