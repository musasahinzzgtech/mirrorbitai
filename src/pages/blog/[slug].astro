---
import Layout from '../../layouts/Layout.astro';
import NavBar from '../../components/NavBar.astro';
import Footer from '../../components/Footer.astro';
import { blogPosts } from '../../data/blogPosts.js';
import '../../styles/global.css';

export function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const related = blogPosts.filter((p) => p.slug !== post.slug).slice(0, 3);
---

<Layout
  title={`${post.title} — Mirrorbit AI`}
  description={post.excerpt}
>
  <NavBar />
  <main class="pt-[52px]">

    <article class="py-16 px-6 lg:px-10">
      <div class="max-w-2xl mx-auto">

        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-[13px] text-[#6E6E73] mb-12">
          <a href="/blog" class="hover:text-[#1D1D1F] transition-colors">Blog</a>
          <span
            class="material-symbols-outlined"
            style="font-size: 14px; font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 20; color: #AEAEB2;"
          >chevron_right</span>
          <span class="text-[#AEAEB2]">{post.category}</span>
        </nav>

        <!-- Meta -->
        <div class="flex items-center gap-2.5 mb-5">
          <span
            class="text-[12px] font-medium text-white bg-[#1D1D1F] px-3 py-1 rounded-full"
          >
            {post.category}
          </span>
          <span class="text-[13px] text-[#AEAEB2]">{post.date}</span>
          <span class="text-[#AEAEB2]">&middot;</span>
          <span class="text-[13px] text-[#AEAEB2]">{post.readTime}</span>
        </div>

        <!-- Title -->
        <h1
          class="headline-display text-[44px] lg:text-[52px] text-[#1D1D1F] mb-5"
        >
          {post.title}
        </h1>

        <!-- Lead -->
        <p
          class="text-[19px] text-[#6E6E73] leading-relaxed mb-10 pb-10"
          style="border-bottom: 1px solid #D2D2D7;"
        >
          {post.excerpt}
        </p>

        <!-- Gradient banner -->
        <div
          class={`h-56 rounded-[20px] bg-gradient-to-br ${post.gradient} mb-12`}
        ></div>

        <!-- Content -->
        <div>
          {post.content.map((section) => (
            <div class="mb-10">
              {section.heading && (
                <h2
                  class="text-[26px] font-semibold text-[#1D1D1F] mb-4"
                  style="letter-spacing: -0.03em; line-height: 1.15;"
                >
                  {section.heading}
                </h2>
              )}
              {section.paragraphs.map((para) => (
                <p
                  class="text-[17px] text-[#1D1D1F] leading-relaxed mb-5"
                  style="letter-spacing: -0.01em;"
                >
                  {para}
                </p>
              ))}
            </div>
          ))}
        </div>

        <!-- Back link -->
        <div class="pt-12 mt-12" style="border-top: 1px solid #D2D2D7;">
          <a
            href="/blog"
            class="inline-flex items-center gap-2 text-[#1D1D1F] text-[15px] hover:opacity-75 transition-opacity"
          >
            <span
              class="material-symbols-outlined"
              style="font-size: 16px; font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 20;"
            >arrow_back</span>
            Back to Blog
          </a>
        </div>

      </div>
    </article>

    <!-- Related posts -->
    {related.length > 0 && (
      <section class="py-16 px-6 lg:px-10 apple-section-alt">
        <div class="max-w-7xl mx-auto">
          <h2
            class="text-[22px] font-semibold text-[#1D1D1F] tracking-tight mb-8"
            style="letter-spacing: -0.02em;"
          >
            More from our blog
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
            {related.map((r) => (
              <a href={`/blog/${r.slug}`} class="blog-card group">
                <div
                  class={`h-40 bg-gradient-to-br ${r.gradient} flex items-end p-4`}
                >
                  <span
                    class="text-[11px] font-medium text-white/90 bg-black/20 px-2.5 py-1 rounded-full backdrop-blur-sm"
                  >
                    {r.category}
                  </span>
                </div>
                <div class="p-5 space-y-2">
                  <p class="text-[12px] text-[#AEAEB2]">{r.date}</p>
                  <h3
                    class="text-[15px] font-semibold text-[#1D1D1F] tracking-tight leading-snug group-hover:text-[#1D1D1F] transition-colors"
                    style="letter-spacing: -0.02em;"
                  >
                    {r.title}
                  </h3>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

  </main>
  <Footer />
</Layout>
